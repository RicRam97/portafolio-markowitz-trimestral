# ══════════════════════════════════════════════════════
# Kaudal — Variables de Entorno
# ══════════════════════════════════════════════════════
# Copia este archivo como .env y llena con tus valores.
# En Railway, configura cada variable en el dashboard → Variables.
# NUNCA subas el archivo .env real a Git.
# ══════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────
# Encuéntralas en: Supabase Dashboard → Settings → API
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJI...tu-anon-key
SUPABASE_JWT_SECRET=tu-jwt-secret-de-supabase

# ── CORS ──────────────────────────────────────────────
# Orígenes permitidos, separados por coma. Sin espacios.
CORS_ORIGINS=https://app.portafolioseficientes.com,http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────
# Formato slowapi: "N/period" (e.g. 10/minute)
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_ANON=2/minute

# ── App ───────────────────────────────────────────────
# development | staging | production
ENVIRONMENT=development

# ══════════════════════════════════════════════════
# FRONTEND (frontend/.env y frontend/.env.local)
# ══════════════════════════════════════════════════
# VITE_API_BASE=http://localhost:8000/api
# VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGci...tu-anon-key

